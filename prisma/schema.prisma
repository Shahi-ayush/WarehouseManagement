model Customer {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  phone     String
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.ObjectId

  sales     Sale[]
  payments  Payment[]

  accounts  CustomerAccount[] // <-- one-to-many
  totalTransactions Int      @default(0)
  totalAmountSpent  Float    @default(0)
  purchasedItems    Json?    // optional for list of purchased item details

  @@unique([userId, phone]) // phone unique only per user
}


model CustomerAccount {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  email      String   @unique
  phone      String   @unique
  password   String
  createdAt  DateTime @default(now())

   status     String   @default("unverified")

  customer   Customer? @relation(fields: [customerId], references: [id],onDelete: SetNull)
  customerId String?   @db.ObjectId
}


model Otp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String?
  phone     String?
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
